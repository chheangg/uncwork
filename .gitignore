# env (any depth)
.env
.env.*
!.env.example

# editor / agent state
.claude/
.idea/
.vscode/

# OS cruft
.DS_Store
Thumbs.db

# build artifacts (defensive; subdirs have their own .gitignore too)
node_modules/
dist/
target/

# scenario runtime state (rewritten every click; defaults live in code)
scenarios/.active
scenarios/.speed

# scenario regen backups
*.ndxml.bak
