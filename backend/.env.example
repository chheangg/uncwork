# Backend secrets and runtime config.
# Copy to backend/.env and fill in your own values. The deploy/local
# scripts source this file before launching the listener, so any
# variable here lands in the listener's process env.
#
# .env is gitignored at the repo root via the catch-all `.env.*` rule.

# Google AI Studio API key for the Gemini-powered AI Recommender and
# multi-agent comms. Without this set the /recommend and /agent/tick
# endpoints return 503 with a clear message.
GEMINI_API_KEY=

# FR-03 neighbor-drag radius in meters. 500 m for the Donetsk-tactical
# demo (default). Bump to ~8000 for a continental ADS-B picture where
# senders are tens of km apart.
# NEIGHBOR_RADIUS_M=500
